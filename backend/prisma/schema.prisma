generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  BUSINESS_OWNER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum CheckoutMethod {
  IN_APP
  MPESA
}

enum ConversationType {
  DIRECT
  GROUP
  BUSINESS_CHAT
}

enum NotificationType {
  NEW_FOLLOWER
  NEW_MESSAGE
  NEW_POV
  ORDER_NEW
  ORDER_STATUS
  SYSTEM
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  phone                 String?   @unique
  password              String
  firstName             String?
  lastName              String?
  role                  UserRole  @default(CUSTOMER)
  interests             String[]
  avatarUrl             String?
  isEmailVerified       Boolean   @default(false)
  isPhoneVerified       Boolean   @default(false)
  emailVerificationToken String?
  mfaEnabled            Boolean   @default(false)
  mfaSecret             String?
  mfaBackupCodes        String[]
  failedAttempts        Int       @default(0)
  lockedUntil           DateTime?
  isBanned              Boolean   @default(false)
  refreshToken          String?
  lastLoginAt           DateTime?
  isOnline              Boolean   @default(false)
  lastSeenAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  ownedBusiness         Business? @relation("BusinessOwner")
  orders                Order[]
  povs                  POV[]
  comments              Comment[]
  likes                 Like[]
  messages              Message[]
  notifications         Notification[]
  sentFollows           Follow[]  @relation("Follower")
  analyticsEvents       AnalyticsEvent[]
  conversationParticipants ConversationParticipant[]
}

model Business {
  id                    String    @id @default(cuid())
  ownerId               String    @unique
  name                  String
  slug                  String    @unique
  description           String?
  category              String?
  type                  String    @default("RETAIL")
  location              String?
  contactPhone          String?
  contactEmail          String?
  operatingHours       Json?
  logoUrl               String?
  coverImageUrl         String?
  isVerified            Boolean   @default(false)
  avgRating             Float     @default(0)
  totalReviews          Int       @default(0)
  totalRecommendations  Int       @default(0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner                 User      @relation("BusinessOwner", fields: [ownerId], references: [id])
  products              Product[]
  povs                  POV[]
  orders                Order[]
  recommendationAds    RecommendationAd[]
}

model Product {
  id                    String    @id @default(cuid())
  businessId            String
  name                  String
  description           String?
  price                 Decimal
  currency              String    @default("KES")
  images                String[]
  category              String?
  stockQuantity         Int       @default(0)
  isService             Boolean   @default(false)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  business              Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]

  @@index([businessId])
  @@index([category])
}

model POV {
  id                    String    @id @default(cuid())
  authorId              String
  businessId            String
  mediaUrl              String
  mediaType             MediaType @default(IMAGE)
  thumbnailUrl          String?
  caption               String?
  starRating            Int       @default(0)
  recommends            Boolean   @default(true)
  isSponsored           Boolean   @default(false)
  viewCount             Int       @default(0)
  likeCount             Int       @default(0)
  commentCount          Int       @default(0)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  author                User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  business              Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  comments              Comment[]
  likes                 Like[]
  recommendationAd      RecommendationAd?

  @@index([authorId])
  @@index([businessId])
}

model Order {
  id                    String    @id @default(cuid())
  customerId            String
  businessId            String
  status                OrderStatus @default(PENDING)
  totalAmount           Decimal
  platformFee           Decimal   @default(0)
  checkoutMethod        CheckoutMethod @default(IN_APP)
  mpesaReceiptNumber    String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  customer              User      @relation(fields: [customerId], references: [id])
  business              Business  @relation(fields: [businessId], references: [id])
  items                 OrderItem[]
  payment               Payment?

  @@index([customerId])
  @@index([businessId])
  @@index([status])
}

model OrderItem {
  id                    String    @id @default(cuid())
  orderId               String
  productId             String
  quantity              Int       @default(1)
  unitPrice             Decimal
  subtotal              Decimal

  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                    String    @id @default(cuid())
  orderId               String    @unique
  mpesaTransactionId   String?
  phoneNumber           String?
  amount                Decimal
  status                String    @default("PENDING")
  callbackPayload      Json?
  createdAt             DateTime  @default(now())

  order                 Order     @relation(fields: [orderId], references: [id])
}

model Message {
  id                    String    @id @default(cuid())
  conversationId        String
  senderId              String
  content               String
  mediaUrl              String?
  readAt                DateTime?
  createdAt             DateTime  @default(now())

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender                User        @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model Conversation {
  id                    String    @id @default(cuid())
  type                  ConversationType @default(DIRECT)
  name                  String?
  lastMessageAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  messages              Message[]
  participants          ConversationParticipant[]

  @@index([type])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id                    String    @id @default(cuid())
  conversationId        String
  userId                String
  joinedAt              DateTime  @default(now())
  lastReadAt            DateTime?

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Follow {
  id                    String    @id @default(cuid())
  followerId            String
  followableId          String
  followableType        String    @default("BUSINESS")
  createdAt             DateTime  @default(now())

  follower              User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followableId, followableType])
  @@index([followerId])
  @@index([followableId])
}

model Notification {
  id                    String    @id @default(cuid())
  userId                String
  type                  NotificationType
  title                 String
  body                  String?
  data                  Json?
  isRead                Boolean   @default(false)
  createdAt             DateTime  @default(now())

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model RecommendationAd {
  id                    String    @id @default(cuid())
  businessId            String
  povId                 String    @unique
  budget                Decimal
  spent                 Decimal   @default(0)
  impressions           Int       @default(0)
  clicks                Int       @default(0)
  status                String    @default("PAUSED")
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  business              Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pov                   POV       @relation(fields: [povId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
}

model Comment {
  id                    String    @id @default(cuid())
  povId                 String
  authorId              String
  content               String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  pov                   POV       @relation(fields: [povId], references: [id], onDelete: Cascade)
  author                User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([povId])
  @@index([authorId])
}

model Like {
  id                    String    @id @default(cuid())
  povId                 String
  userId                String
  createdAt             DateTime  @default(now())

  pov                   POV       @relation(fields: [povId], references: [id], onDelete: Cascade)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([povId, userId])
  @@index([povId])
  @@index([userId])
}

model Interest {
  id                    String    @id @default(cuid())
  name                  String    @unique
  slug                  String    @unique
  iconUrl              String?
  createdAt             DateTime  @default(now())

  @@index([slug])
}

model AnalyticsEvent {
  id                    String    @id @default(cuid())
  eventType             String
  userId                String?
  businessId            String?
  productId             String?
  metadata              Json?
  createdAt             DateTime  @default(now())

  user                  User?     @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([userId])
  @@index([businessId])
  @@index([createdAt])
}

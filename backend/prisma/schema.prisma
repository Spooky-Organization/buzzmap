generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CUSTOMER
  BUSINESS_OWNER
}

enum BusinessType {
  PRODUCTS
  SERVICES
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
}

enum POVMediaType {
  IMAGE
  VIDEO
}

enum POVVisibility {
  PUBLIC
  FOLLOWERS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ConversationType {
  DIRECT
  GROUP
}

enum NotificationType {
  POV_POSTED
  ORDER_UPDATE
  NEW_FOLLOWER
  MESSAGE
  FRIEND_JOINED
}

enum ReportTargetType {
  POV
  USER
  BUSINESS
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum AnalyticsEventType {
  BUSINESS_VIEWED
  PRODUCT_VIEWED
  POV_VIEWED
  ADD_TO_CART
  CHECKOUT_STARTED
  ORDER_PLACED
  MESSAGE_STARTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  password  String
  name      String
  avatar    String?
  role      Role
  interests String[]
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfile          BusinessProfile?
  povs                     POV[]
  posts                    Post[]
  comments                 Comment[]
  likes                    Like[]
  orders                   Order[]
  cartItems                CartItem[]
  analyticsEvents          AnalyticsEvent[]
  follows                  Follow[]                  @relation("following")
  followers                Follow[]                  @relation("followedBy")
  sentMessages             Message[]
  notifications            Notification[]
  reports                  Report[]
  conversationParticipants ConversationParticipant[]
}

model BusinessProfile {
  id             String       @id @default(uuid())
  userId         String       @unique
  businessName   String
  description    String
  category       String
  type           BusinessType
  location       String
  coordinates    String?
  contactInfo    String
  operatingHours Json
  isVerified     Boolean      @default(false)
  qrCode         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  products Product[]
  povs     POV[]
  posts    Post[]
}

model POV {
  id            String   @id @default(uuid())
  authorId      String
  businessId    String?
  caption       String?
  starRating    Int?
  recommends    Boolean?
  visibility     POVVisibility @default(PUBLIC)
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  createdAt     DateTime @default(now())

  author   User            @relation(fields: [authorId], references: [id])
  business BusinessProfile? @relation(fields: [businessId], references: [id])
  media    POVMedia[]
  comments Comment[]
  likes    Like[]

  @@index([businessId, createdAt])
  @@index([authorId])
}

model POVMedia {
  id           String       @id @default(uuid())
  povId        String
  url          String // storage key (not a signed URL)
  type         POVMediaType
  thumbnailUrl String?
  position     Int // 0-based order within the gallery
  createdAt    DateTime     @default(now())

  pov POV @relation(fields: [povId], references: [id], onDelete: Cascade)

  @@index([povId, position])
}

model Post {
  id         String   @id @default(uuid())
  authorId   String
  businessId String?
  type       PostType
  content    String?
  mediaUrls  String[]
  createdAt  DateTime @default(now())

  author   User             @relation(fields: [authorId], references: [id])
  business BusinessProfile? @relation(fields: [businessId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  povId     String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pov  POV  @relation(fields: [povId], references: [id])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  povId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pov  POV  @relation(fields: [povId], references: [id])

  @@unique([userId, povId])
}

model Product {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String
  price       Float
  currency    String   @default("KES")
  images      String[]
  stock       Int
  category    String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business   BusinessProfile @relation(fields: [businessId], references: [id])
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([businessId, isAvailable])
  @@index([category])
}

model Order {
  id          String      @id @default(uuid())
  customerId  String
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer User        @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@index([customerId, status])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model CartItem {
  id        String @id @default(uuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followedBy", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  name      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  mediaUrl       String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
}

model Report {
  id         String           @id @default(uuid())
  reporterId String
  targetType ReportTargetType
  targetId   String
  reason     String
  status     ReportStatus     @default(PENDING)
  createdAt  DateTime         @default(now())

  reporter User @relation(fields: [reporterId], references: [id])
}

model AnalyticsEvent {
  id             String             @id @default(uuid())
  userId         String
  eventType      AnalyticsEventType
  businessId     String?
  productId      String?
  povId          String?
  orderId        String?
  conversationId String?
  metadata       Json?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([businessId, createdAt])
  @@index([productId, createdAt])
  @@index([povId, createdAt])
  @@index([orderId, createdAt])
  @@index([conversationId, createdAt])
}

FROM node:22-alpine

# System deps for bcrypt native build
RUN apk add --no-cache python3 make g++

WORKDIR /app

# Layer 1: dependency install (cached unless package*.json changes)
COPY package*.json ./
RUN npm ci --include=dev && npm cache clean --force

# Layer 2: Prisma generate (cached unless schema changes)
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN npx prisma generate

# Layer 3: source (overridden by volume mount in dev anyway)
COPY . .

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["entrypoint.sh"]
# Polling-based watcher (nodemon --legacy-watch): the dev bind mount does not
# propagate inotify events, so tsx's native watcher never sees edits. Polling
# via nodemon is what makes hot reload work in this container.
CMD ["npm", "run", "dev"]

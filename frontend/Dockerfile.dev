FROM node:22-alpine

WORKDIR /app

# Layer 1: dependency install (cached unless package*.json changes)
COPY package*.json ./
RUN npm ci --include=dev && npm cache clean --force

# Layer 2: source (overridden by volume mount in dev anyway)
COPY . .

# Next.js telemetry off in dev
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["npm", "run", "dev"]
